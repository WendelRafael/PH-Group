# ============================================================
# PH Catálogo — credenciais do ambiente local
#
# Copie este arquivo para `.env` e ajuste se o seu MySQL for
# diferente do padrão Laragon/XAMPP (root sem senha).
# Sem `.env`, a aplicação usa exatamente os valores abaixo.
# ============================================================

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ph_catalogo
DB_USER=root
DB_PASS=
